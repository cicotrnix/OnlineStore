# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5435/online_store_dev"

# Auth.js
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-me-with-a-real-secret"
NEXTAUTH_URL="http://localhost:3000"

# Email (Resend) — used for magic link sign-in
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="onboarding@resend.dev"

# Observability (Sentry)
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# Search (Meilisearch Cloud + Voyage)
# Leave empty for dev/test — wrappers fall back to no-op + Postgres LIKE.
MEILISEARCH_HOST="https://ms-xxxxx.xxx.meilisearch.io"
MEILISEARCH_API_KEY="your-default-admin-api-key"
VOYAGE_API_KEY="pa-xxxxxxxxxxxx"

# AI (Anthropic) — vacío = IA inerte (noop). Budget 0 = sin límite.
ANTHROPIC_API_KEY=""
AI_MONTHLY_TOKEN_BUDGET="0"

# Stripe — OBLIGATORIAS en producción (o con payments.stripe.enabled).
# Decisión 3 / ADR 0038: si faltan en prod, el boot lanza (no degrada al
# FakeStripe forjable). En dev/test vacías = FakeStripe in-memory.
# El endpoint del Dashboard debe enviar: checkout.session.completed,
# payment_intent.payment_failed y charge.refunded.
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Environment
NODE_ENV="development"

# Tienda activa. Obligatorio en producción (fail-fast al boot si falta).
# En dev/test, default 'pipower' si no se setea.
STORE_ID=pipower
