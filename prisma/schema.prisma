generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ===== Auth.js =====

enum CatalogView {
  CARDS
  LIST
}

model User {
  id                   String      @id @default(cuid())
  email                String      @unique
  emailVerified        DateTime?
  name                 String?
  image                String?
  isPlatformAdmin      Boolean     @default(false)
  preferredCatalogView CatalogView @default(CARDS)
  preferredLocale      String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  accounts          Account[]
  sessions          Session[]
  memberships       OrganizationMember[]
  cart              Cart?
  placedOrders      Order[]              @relation("OrderPlacedBy")
  cancelledOrders   Order[]              @relation("OrderCancelledBy")
  impersonationLogs ImpersonationLog[]   @relation("ImpersonationAdmin")

  // ─── Fase 2 ───
  quotesRequested      Quote[]                     @relation("QuoteRequester")
  quotesAuthored       Quote[]                     @relation("QuoteAuthor")
  quoteAuditLogs       QuoteAuditLog[]
  approvalsRequested   ApprovalRequest[]           @relation("ApprovalRequester")
  approvalsDecided     ApprovalRequest[]           @relation("ApprovalDecider")
  notifications        Notification[]
  invoicesPaidBy       Invoice[]
  catalogAccessGranted OrganizationCatalogAccess[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id                 String   @id @default(cuid())
  sessionToken       String   @unique
  userId             String
  expires            DateTime
  activeOrgId        String?
  impersonatingOrgId String?
  lastSeenAt         DateTime @default(now())

  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeOrg        Organization? @relation("SessionActiveOrg", fields: [activeOrgId], references: [id], onDelete: SetNull)
  impersonatingOrg Organization? @relation("SessionImpersonatingOrg", fields: [impersonatingOrgId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([activeOrgId])
  @@index([impersonatingOrgId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ===== B2B =====

enum OrgRole {
  OWNER
  ADMIN
  BUYER
  VIEWER
}

enum PaymentTerms {
  PREPAID
  NET_15
  NET_30
  NET_60
}

enum ApprovalRole {
  OWNER
  ADMIN
}

model Organization {
  id                String         @id @default(cuid())
  name              String
  slug              String         @unique
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  // ─── Fase 2 ───
  creditLimit       Decimal?       @db.Decimal(12, 2)
  creditUsed        Decimal        @default(0) @db.Decimal(12, 2)
  paymentTerms      PaymentTerms   @default(PREPAID)
  approvalThreshold Decimal?       @db.Decimal(12, 2)
  approvalRoles     ApprovalRole[] @default([OWNER, ADMIN])
  // ─── Fase 5: verificación B2B ───
  verificationStatus VerificationStatus @default(PENDING)
  country            String?
  taxExempt          Boolean            @default(false)
  verifiedAt         DateTime?

  members               OrganizationMember[]
  taxDocuments          TaxDocument[]
  invitations           Invitation[]
  addresses             OrganizationAddress[]
  customerPrices        CustomerPrice[]
  orders                Order[]
  activeSessions        Session[]                   @relation("SessionActiveOrg")
  impersonatingSessions Session[]                   @relation("SessionImpersonatingOrg")
  impersonationLogs     ImpersonationLog[]          @relation("ImpersonationTarget")
  quotes                Quote[]
  invoices              Invoice[]
  approvalRequests      ApprovalRequest[]
  catalogAccess         OrganizationCatalogAccess[]
}

model OrganizationMember {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           OrgRole  @default(BUYER)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
}

model Invitation {
  id             String    @id @default(cuid())
  organizationId String
  email          String
  role           OrgRole   @default(BUYER)
  token          String    @unique
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
}

model OrganizationAddress {
  id                String   @id @default(cuid())
  organizationId    String
  label             String
  recipient         String
  line1             String
  line2             String?
  city              String
  state             String?
  postalCode        String
  country           String
  phone             String?
  isDefaultBilling  Boolean  @default(false)
  isDefaultShipping Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  billingForOrders  Order[]      @relation("OrderBilling")
  shippingForOrders Order[]      @relation("OrderShipping")

  @@index([organizationId])
}

// ===== catalog =====

model Category {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  isPrivate   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products      Product[]
  catalogAccess OrganizationCatalogAccess[]
}

model Product {
  id                 String                      @id @default(cuid())
  sku                String                      @unique
  slug               String                      @unique
  name               String
  description        String?
  basePrice          Decimal                     @db.Decimal(12, 2)
  stockQuantity      Int                         @default(0)
  imageUrl           String?
  isActive           Boolean                     @default(true)
  isPrivate          Boolean                     @default(false)
  categoryId         String
  embedding          Unsupported("vector(512)")?
  embeddingUpdatedAt DateTime?
  searchableText     String?                     @db.Text
  attributes         Json?
  compatibleModels   String[]
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt

  category       Category                    @relation(fields: [categoryId], references: [id])
  customerPrices CustomerPrice[]
  cartItems      CartItem[]
  orderLines     OrderLine[]
  priceTiers     ProductPriceTier[]
  catalogAccess  OrganizationCatalogAccess[]
  quoteLines     QuoteLine[]
  content        ProductContent[]

  @@index([categoryId])
  @@index([isActive])
}

enum ProductContentStatus {
  DRAFT
  PUBLISHED
}

model ProductContent {
  id                String               @id @default(cuid())
  productId         String
  locale            String
  longDescriptionMd String?              @db.Text
  shortDescription  String?
  seoTitle          String?
  seoDescription    String?
  status            ProductContentStatus @default(DRAFT)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, locale])
  @@index([productId])
}

// ===== pricing =====

model CustomerPrice {
  id             String    @id @default(cuid())
  organizationId String
  productId      String
  price          Decimal   @db.Decimal(12, 2)
  validFrom      DateTime?
  validUntil     DateTime?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([organizationId, productId])
  @@index([organizationId])
}

// ===== cart =====

model Cart {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]
}

model CartItem {
  id                     String   @id @default(cuid())
  cartId                 String
  productId              String
  quantity               Int
  unitPriceSnapshot      Decimal  @db.Decimal(12, 2)
  discountAmountSnapshot Decimal  @default(0) @db.Decimal(12, 2)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
  @@index([cartId])
}

// ===== orders =====

enum OrderStatus {
  PENDING_PAYMENT
  PENDING_APPROVAL
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  PREPAID
  NET_TERMS
}

model Order {
  id                String        @id @default(cuid())
  orderNumber       String        @unique
  organizationId    String
  placedByUserId    String
  status            OrderStatus   @default(PENDING_PAYMENT)
  paymentMethod     PaymentMethod @default(PREPAID)
  poNumber          String?
  notes             String?
  billingAddressId  String
  shippingAddressId String
  subtotal          Decimal       @db.Decimal(12, 2)
  total             Decimal       @db.Decimal(12, 2)
  currency          String
  placedAt          DateTime      @default(now())
  confirmedAt       DateTime?
  shippedAt         DateTime?
  deliveredAt       DateTime?
  cancelledAt       DateTime?
  cancelledByUserId String?

  organization      Organization        @relation(fields: [organizationId], references: [id])
  placedBy          User                @relation("OrderPlacedBy", fields: [placedByUserId], references: [id])
  cancelledBy       User?               @relation("OrderCancelledBy", fields: [cancelledByUserId], references: [id])
  billingAddress    OrganizationAddress @relation("OrderBilling", fields: [billingAddressId], references: [id])
  shippingAddress   OrganizationAddress @relation("OrderShipping", fields: [shippingAddressId], references: [id])
  lines             OrderLine[]
  invoice           Invoice?
  payment           Payment?
  approvedFromQuote Quote?              @relation("QuoteConvertedOrder")

  @@index([organizationId])
  @@index([status])
}

model OrderLine {
  id             String   @id @default(cuid())
  orderId        String
  productId      String
  sku            String
  name           String
  unitPrice      Decimal  @db.Decimal(12, 2)
  quantity       Int
  discountAmount Decimal  @default(0) @db.Decimal(12, 2)
  lineTotal      Decimal  @db.Decimal(12, 2)
  createdAt      DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
}

// ===== audit / impersonation =====

enum ImpersonationAction {
  START
  STOP
}

model ImpersonationLog {
  id          String              @id @default(cuid())
  adminUserId String
  targetOrgId String
  action      ImpersonationAction
  reason      String?
  createdAt   DateTime            @default(now())

  adminUser User         @relation("ImpersonationAdmin", fields: [adminUserId], references: [id])
  targetOrg Organization @relation("ImpersonationTarget", fields: [targetOrgId], references: [id])

  @@index([adminUserId])
  @@index([targetOrgId])
  @@index([createdAt])
}

// ===== Fase 2: quotes =====

enum QuoteStatus {
  DRAFT
  SUBMITTED
  QUOTED
  ACCEPTED
  REJECTED
  EXPIRED
}

model Quote {
  id               String      @id @default(cuid())
  number           String      @unique
  organizationId   String
  requestedById    String
  status           QuoteStatus @default(DRAFT)
  submittedAt      DateTime?
  quotedAt         DateTime?
  quotedById       String?
  validUntil       DateTime?
  decidedAt        DateTime?
  decidedById      String?
  notes            String?     @db.Text
  adminNotes       String?     @db.Text
  currency         String
  subtotal         Decimal     @default(0) @db.Decimal(12, 2)
  total            Decimal     @default(0) @db.Decimal(12, 2)
  revisionCount    Int         @default(0)
  lastRevisedAt    DateTime?
  convertedOrderId String?     @unique
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id])
  requestedBy    User            @relation("QuoteRequester", fields: [requestedById], references: [id])
  quotedBy       User?           @relation("QuoteAuthor", fields: [quotedById], references: [id])
  convertedOrder Order?          @relation("QuoteConvertedOrder", fields: [convertedOrderId], references: [id])
  lines          QuoteLine[]
  auditLog       QuoteAuditLog[]

  @@index([organizationId, status])
  @@index([requestedById])
}

model QuoteLine {
  id              String   @id @default(cuid())
  quoteId         String
  productId       String
  sku             String
  name            String
  qty             Int
  unitPriceBase   Decimal  @db.Decimal(12, 2)
  unitPriceQuoted Decimal? @db.Decimal(12, 2)
  lineTotal       Decimal  @default(0) @db.Decimal(12, 2)
  order           Int      @default(0)

  quote   Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([quoteId])
}

model QuoteAuditLog {
  id        String   @id @default(cuid())
  quoteId   String
  action    String
  actorId   String?
  payload   Json?
  createdAt DateTime @default(now())

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  actor User? @relation(fields: [actorId], references: [id])

  @@index([quoteId])
}

// ===== Fase 2: accounts =====

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

model Invoice {
  id             String        @id @default(cuid())
  number         String        @unique
  organizationId String
  orderId        String        @unique
  status         InvoiceStatus @default(PENDING)
  amount         Decimal       @db.Decimal(12, 2)
  currency       String
  issuedAt       DateTime      @default(now())
  dueDate        DateTime
  paidAt         DateTime?
  paidNote       String?       @db.Text
  paidById       String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  order        Order        @relation(fields: [orderId], references: [id])
  paidBy       User?        @relation(fields: [paidById], references: [id])

  @@index([organizationId, status])
  @@index([dueDate, status])
}

// ===== Fase 2: approvals =====

enum ApprovalSubject {
  ORDER
  QUOTE
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model ApprovalRequest {
  id             String          @id @default(cuid())
  organizationId String
  subjectType    ApprovalSubject
  subjectId      String
  requestedById  String
  threshold      Decimal         @db.Decimal(12, 2)
  amount         Decimal         @db.Decimal(12, 2)
  status         ApprovalStatus  @default(PENDING)
  decidedById    String?
  decidedAt      DateTime?
  reason         String?         @db.Text
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  requestedBy  User         @relation("ApprovalRequester", fields: [requestedById], references: [id])
  decidedBy    User?        @relation("ApprovalDecider", fields: [decidedById], references: [id])

  @@index([organizationId, status])
  @@index([subjectType, subjectId])
}

// ===== Fase 2: notifications =====

enum NotificationType {
  QUOTE_SUBMITTED
  QUOTE_QUOTED
  QUOTE_REVISED
  QUOTE_ACCEPTED
  QUOTE_REJECTED
  QUOTE_EXPIRING
  APPROVAL_REQUESTED
  APPROVAL_GRANTED
  APPROVAL_REJECTED
  INVOICE_DUE_SOON
  INVOICE_OVERDUE
  INVOICE_PAID
  CREDIT_LIMIT_WARNING
  CREDIT_BLOCKED
}

model Notification {
  id                String           @id @default(cuid())
  userId            String
  type              NotificationType
  subjectType       String?
  subjectId         String?
  title             String
  body              String           @db.Text
  link              String?
  readAt            DateTime?
  emailSentAt       DateTime?
  emailFailedReason String?
  emailRetryCount   Int              @default(0)
  createdAt         DateTime         @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, readAt])
  @@index([createdAt])
  @@index([emailSentAt])
}

// ===== Fase 2: catalog extensions =====

model OrganizationCatalogAccess {
  id             String   @id @default(cuid())
  organizationId String
  productId      String?
  categoryId     String?
  grantedById    String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product      Product?     @relation(fields: [productId], references: [id], onDelete: Cascade)
  category     Category?    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  grantedBy    User         @relation(fields: [grantedById], references: [id])

  @@unique([organizationId, productId])
  @@unique([organizationId, categoryId])
  @@index([organizationId])
}

// ===== Fase 2: pricing extension =====

model ProductPriceTier {
  id        String   @id @default(cuid())
  productId String
  minQty    Int
  unitPrice Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, minQty])
  @@index([productId])
}

// ===== Fase 3: search index queue =====

enum SearchIndexAction {
  UPSERT
  DELETE
}

enum SearchIndexStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

model SearchIndexQueue {
  id          String            @id @default(cuid())
  productId   String
  action      SearchIndexAction
  status      SearchIndexStatus @default(PENDING)
  attempts    Int               @default(0)
  lastError   String?           @db.Text
  enqueuedAt  DateTime          @default(now())
  processedAt DateTime?

  @@index([status, enqueuedAt])
  @@index([productId])
}

// ===== Fase 4: AI usage tracking =====

model AiUsage {
  id         String   @id @default(cuid())
  periodYm   String   @unique // "YYYY-MM"
  tokensUsed Int      @default(0)
  updatedAt  DateTime @updatedAt
}

// ===== Fase 4: AI content generation queue =====

enum AiJobStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

model AiContentJob {
  id          String      @id @default(cuid())
  productId   String
  locale      String
  status      AiJobStatus @default(PENDING)
  attempts    Int         @default(0)
  lastError   String?     @db.Text
  enqueuedAt  DateTime    @default(now())
  processedAt DateTime?

  @@index([status, enqueuedAt])
  @@index([productId])
}

// ===== Fase 5: bus de eventos (outbox) =====

enum DomainEventStatus {
  PENDING
  PROCESSING
  DONE
}

enum EventDeliveryStatus {
  PENDING
  DONE
  FAILED
}

model DomainEvent {
  id            String            @id @default(cuid())
  type          String
  aggregateType String
  aggregateId   String
  payload       Json
  status        DomainEventStatus @default(PENDING)
  occurredAt    DateTime          @default(now())
  createdAt     DateTime          @default(now())
  deliveries    EventDelivery[]

  @@index([status, occurredAt])
  @@index([aggregateType, aggregateId])
}

model EventDelivery {
  id          String              @id @default(cuid())
  eventId     String
  event       DomainEvent         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  subscriber  String
  status      EventDeliveryStatus @default(PENDING)
  attempts    Int                 @default(0)
  lastError   String?             @db.Text
  processedAt DateTime?
  createdAt   DateTime            @default(now())

  @@unique([eventId, subscriber])
  @@index([status])
}

// ===== Fase 5: verificación B2B =====

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum TaxDocumentType {
  US_RESALE_CERT
  FOREIGN_EQUIV
}

enum TaxDocumentStatus {
  UPLOADED
  APPROVED
  REJECTED
}

model TaxDocument {
  id             String            @id @default(cuid())
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type           TaxDocumentType
  number         String
  jurisdiction   String
  fileKey        String
  status         TaxDocumentStatus @default(UPLOADED)
  uploadedAt     DateTime          @default(now())
  reviewedAt     DateTime?
  reviewedById   String?

  @@index([organizationId])
}

// ===== Fase 5 Corte 2: Pagos =====

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  REFUNDED
  FAILED
  NEEDS_REVIEW
}

enum PaymentMethodType {
  STRIPE_CARD
  WIRE
  ACH
}

model Payment {
  id              String            @id @default(cuid())
  orderId         String            @unique
  order           Order             @relation(fields: [orderId], references: [id])
  method          PaymentMethodType
  status          PaymentStatus     @default(PENDING)
  amountCents     BigInt
  currency        String
  // referencias externas
  stripeSessionId String?           @unique
  stripeIntentId  String?           @unique
  idempotencyKey  String?           @unique
  // wire
  wireReference   String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  events          PaymentEvent[]

  @@index([status])
}

model PaymentEvent {
  id        String   @id @default(cuid())
  paymentId String
  payment   Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  eventId   String   @unique // Stripe event.id o uuid del wire
  type      String   // ej: checkout.session.completed
  payload   Json
  createdAt DateTime @default(now())

  @@index([paymentId])
}

// ===== Fase 5: Step-up auth (sensitive actions) =====

enum SensitiveActionStatus {
  ISSUED
  USED
  EXPIRED
}

model SensitiveActionToken {
  id        String                @id @default(cuid())
  userId    String
  action    String                // ej: 'payment.refund'
  subjectId String                // ej: paymentId
  tokenHash String                @unique
  otpHash   String
  status    SensitiveActionStatus @default(ISSUED)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime              @default(now())

  @@index([userId, action])
}
